<?xml version="1.0" encoding="utf-8"?>
<!-- Runsettings para proyectos de test de dominio (*.Domain.UnitTests).
     Solo mide el assembly Domain — no incluye Application para evitar
     falsos 0% en clases que los tests de dominio no ejercitan. -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
          <ExcludeByFile>**/Migrations/*.cs,**/Program.cs,**/Startup.cs</ExcludeByFile>
          <Include>[*.Domain]*</Include>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
